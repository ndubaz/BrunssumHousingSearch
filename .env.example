# Copy this to .env.local for local testing with `vercel dev`.
# In production, set these in the Vercel project's Settings > Environment Variables instead.

# Provided automatically if you connect an Upstash Redis database via the
# Vercel Marketplace integration. Otherwise, copy them from your Upstash
# database's REST API section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Shared password for you and your wife to unlock the tracker.
# Anyone with this password and the URL can read/write the shared data.
SITE_PASSWORD=
